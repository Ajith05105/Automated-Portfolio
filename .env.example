GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=portfolio-builder-494211
GOOGLE_CLOUD_LOCATION=us-central1

# Stitch API key — https://stitch.withgoogle.com/settings
STITCH_API_KEY=your-stitch-api-key

# Drive folder where attendees upload their CV docs
DRIVE_FOLDER_ID=your-drive-folder-id

# Google Sheet ID for the results tracking sheet
# (the part of the URL between /d/ and /edit)
RESULTS_SHEET_ID=your-sheet-id

# Gmail SMTP credentials for the delivery agent
# Generate an app password at: https://myaccount.google.com/apppasswords
GMAIL_USER=example@gmail.com
GMAIL_APP_PASSWORD=generatedapppassword
